# ─────────────────────────────────────────────────────────────
# OpenCode Scanner — environment template
# ─────────────────────────────────────────────────────────────
# Copy this to `.env` and fill in real values, OR just run
# `./start.sh` which generates a fresh `.env` with random secrets.
#
# `.env` itself is git-ignored — NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# Port the web UI is served on (nginx).
WEB_PORT=12211

# Signs JWT login tokens. Generate with: openssl rand -hex 24
SECRET_KEY=change-me-to-a-random-string

# Encrypts proxy/SSH credentials stored in the database (Fernet).
# Generate with: openssl rand -hex 24
#
# IMPORTANT when restoring a DB backup from another instance:
#   this MUST match the source instance's ENCRYPTION_KEY, otherwise
#   the restored proxy/machine passwords won't decrypt.
ENCRYPTION_KEY=change-me-to-a-random-string

# PostgreSQL credentials (only used on FIRST init of the db volume).
POSTGRES_USER=scanner
POSTGRES_PASSWORD=change-me-to-a-random-password
POSTGRES_DB=opencode_scanner
